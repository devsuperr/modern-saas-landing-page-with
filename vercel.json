{
  "rewrites": [
    {
      "source": "/blog",
      "destination": "/blog-en.html"
    },
    {
      "source": "/blogg",
      "destination": "/blog-no.html"
    },
    {
      "source": "/english",
      "destination": "/english.html"
    },
    {
      "source": "/solutions",
      "destination": "/solutions-en.html"
    },
    {
      "source": "/losninger",
      "destination": "/solutions-no.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}